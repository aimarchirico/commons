{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig-base.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "${configDir}/src",
    "outDir": "${configDir}/dist"
  },
  "include": ["${configDir}/src/bin/**/*.ts"]
}
