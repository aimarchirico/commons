{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true
  },
  "include": [
    "packages/**/*.js"
  ],
  "exclude": [
    "**/node_modules",
    "**/build",
    "**/dist"
  ]
}
